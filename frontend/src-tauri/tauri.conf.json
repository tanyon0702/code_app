{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Self Evolution Desk",
  "version": "0.1.0",
  "identifier": "com.local.selfevolutiondesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Self Evolution Desk",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
